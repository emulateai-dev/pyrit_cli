# Copy to .env.local (project) or export in shell before running pyrit-cli.
#
# Phoenix/OpenTelemetry integration is fail-open:
# - If disabled below, nothing is instrumented.
# - If initialization fails, pyrit-cli auto-disables tracing.

# Enable/disable tracing (default true when unset).
PHOENIX_TRACING_ENABLED=true

# Phoenix OTLP HTTP collector endpoint.
# If you start docker-compose.phoenix.yml locally, use:
#   http://127.0.0.1:16007/v1/traces
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:16007/v1/traces

# Optional project name shown in Phoenix.
PHOENIX_PROJECT_NAME=pyrit-cli-lab

# Recommended by Phoenix docs for richer agent tracing:
# keep auto-instrumentation enabled unless debugging instrumentation issues.
PHOENIX_AUTO_INSTRUMENT=true
